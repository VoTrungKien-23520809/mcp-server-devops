# Local runtime configuration for main.py
JENKINS_URL=http://127.0.0.1:8080
JENKINS_USER=jenkins-user
JENKINS_TOKEN=replace-with-real-token

# Optional tuning
LOG_LEVEL=INFO
HTTP_TIMEOUT_SECONDS=10
TERRAFORM_TIMEOUT_SECONDS=120
MAX_JENKINS_LOG_LENGTH=5000
MAX_CODE_CONTEXT_LENGTH=10000
WORKSPACE_ROOT=/app
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
AI_TIMEOUT_SECONDS=30
KUBECTL_TIMEOUT_SECONDS=15
MAX_K8S_OUTPUT_LENGTH=8000
