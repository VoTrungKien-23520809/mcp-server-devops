pipeline {
    agent any

    // 1. KHỐI PARAMETERS: Tạo form nhập link Tunnel trên giao diện Jenkins
    parameters {
        string(name: 'AI_AGENT_WEBHOOK', defaultValue: '', description: 'Nhập link Tunnel (Localtunnel/Ngrok) của bạn để nhận báo lỗi (Lưu ý: Bỏ đuôi /webhook). Để trống nếu không muốn gọi AI.')
    }

    environment {
        DOCKER_HUB_USER = "trgqn" 
        APP_NAME = "meteo-hist" 
        IMAGE_TAG = "${DOCKER_HUB_USER}/${APP_NAME}:latest"
    }

    stages {
        stage('Checkout Code') {
            steps {
                echo 'Fetching the latest weather app code from GitHub...'
                checkout scm 
                echo '✅ Code checkout successful!'
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('weather-app'){
                    echo "Building the Docker image: ${IMAGE_TAG}..."
                    sh "docker build -t ${IMAGE_TAG} ."
                    echo '✅ Docker image built successfully!'
                }
            }
        }

        stage('Security Scan (Trivy)') {
            steps {
                dir('weather-app'){
                    echo 'Scanning the weather app Docker image for critical vulnerabilities...'
                    sh "trivy image --db-repository ghcr.io/aquasecurity/trivy-db:2 --severity CRITICAL --exit-code 1 ${IMAGE_TAG}"
                    echo '✅ Scan completed. No CRITICAL issues detected!'
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                echo 'Pushing the weather app image to Docker Hub...'
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials-trgqn', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                        docker push ''' + "${IMAGE_TAG}" + '''
                    '''
                }
                echo '✅ Image successfully pushed to Docker Hub Registry!'
            }
        }

        stage('Deploy to K3s') {
            steps {
                dir('weather-app'){
                    echo 'Deploying weather app to K3s environment...'
                    sh '''
                    export KUBECONFIG=/etc/rancher/k3s/k3s.yaml
                    
                    kubectl apply -f k8s/deployment.yaml
                    
                    kubectl rollout restart deployment/meteo-hist-deployment -n default
                    '''
                    echo '✅ Deployment successful!'
                }
            }
        }
    }
    
    // 2. KHỐI POST: Đọc tham số từ UI và bắn Webhook
    post {
        always {
            script {
                echo "📣 Đang báo cáo kết quả cho AI Agent..."
                
                // Dùng params.AI_AGENT_WEBHOOK thay vì env. Kiểm tra xem người dùng có nhập link không.
                if (params.AI_AGENT_WEBHOOK?.trim()) {
                    // Tự động nối thêm đuôi /webhook vào URL gốc
                    def webhookUrl = "${params.AI_AGENT_WEBHOOK.trim()}/webhook" 
                    
                    def payload = """
                    {
                        "job_name": "${JOB_NAME}",
                        "build_number": "${BUILD_NUMBER}",
                        "status": "${currentBuild.currentResult}"
                    }
                    """
                    
                    sh """
                    curl -X POST \
                    -H "Content-Type: application/json" \
                    -H "Bypass-Tunnel-Reminder: true" \
                    -d '${payload}' ${webhookUrl}
                    """
                    echo "✅ Đã gửi tín hiệu trạng thái (${currentBuild.currentResult}) tới AI Agent tại: ${webhookUrl}"
                } else {
                    echo "⚠️ LƯU Ý: Không có link Tunnel nào được nhập. Bỏ qua gọi AI."
                }
            }
        }
    }
}
